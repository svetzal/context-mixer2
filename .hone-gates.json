{
  "gates": [
    {
      "name": "format",
      "command": "cargo fmt --check",
      "required": true
    },
    {
      "name": "lint",
      "command": "cargo clippy --all-targets --all-features -- -D warnings",
      "required": true
    },
    {
      "name": "test",
      "command": "cargo test --all-features",
      "required": true
    },
    {
      "name": "deny",
      "command": "cargo deny check",
      "required": true
    }
  ]
}
